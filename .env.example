# NeoSpartan Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Security (REQUIRED - generate a strong random key)
SECRET_KEY=your-secure-random-secret-key-here

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_ANON_KEY=your-supabase-anon-key

# AI - Gemini API Key (REQUIRED for AI features)
# Get your key at: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# AI - OpenAI (Optional - fallback AI provider)
# OPENAI_API_KEY=your-openai-api-key-here

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Settings (adjust for your frontend URL)
CORS_ORIGINS=http://localhost:3000,https://your-app.com

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# Redis (Optional - for caching and background tasks)
# REDIS_URL=redis://localhost:6379/0

# Monitoring (Optional)
# SENTRY_DSN=your-sentry-dsn-here

# ============================================
# FLUTTER APP CONFIGURATION
# ============================================
# Note: Flutter uses --dart-define for compile-time variables
# Example: flutter run --dart-define=GEMINI_API_KEY=your_key_here

# Or add to your IDE launch configuration:
# "toolArgs": ["--dart-define", "GEMINI_API_KEY=your_key_here"]
