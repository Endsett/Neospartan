# ============================================
# NeoSpartan Backend Environment Configuration
# ============================================

# Application
APP_NAME="NeoSpartan AI"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT="development"  # development, staging, production

# Server
HOST="0.0.0.0"
PORT=8000
WORKERS=1

# Security
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://neospartan.app,http://localhost:64847"
ALLOWED_HOSTS="api.neospartan.ai,localhost,127.0.0.1"

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# Supabase (REQUIRED)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# AI - Google Gemini (REQUIRED)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"  # or gemini-1.5-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# AI - OpenAI (Optional - for fallback)
OPENAI_API_KEY="your-openai-api-key-optional"
OPENAI_MODEL="gpt-4-turbo-preview"

# Redis (for caching & background tasks)
REDIS_URL="redis://localhost:6379/0"

# Background Tasks
ARQ_WORKER_ENABLED=true
ARQ_MAX_JOBS=100
ARQ_JOB_TIMEOUT=300

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
JSON_LOGS=true

# Monitoring (Optional)
SENTRY_DSN="https://your-sentry-dsn.sentry.io/optional"
ENABLE_METRICS=true
