  Widget _buildPhilosophicalDatabaseSection() {
    final philosophers = [
      {
        'name': 'Marcus Aurelius',
        'title': 'Meditations',
        'image': 'meditations',
      },
      {'name': 'Seneca', 'title': 'Letters', 'image': 'seneca'},
      {'name': 'Epictetus', 'title': 'Discourses', 'image': 'epictetus'},
      {'name': 'Musonius Rufus', 'title': 'Lectures', 'image': 'musonius'},
    ];

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
