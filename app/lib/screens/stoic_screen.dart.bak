                ),
                const SizedBox(width: 16),
                Container(width: 12, height: 12, color: LaconicTheme.primary),
                const SizedBox(width: 8),
                Text(
                  'Power Output',
                  style: GoogleFonts.workSans(
                    fontSize: 10,
                    color: LaconicTheme.primary,
                  ),
                ),
              ],
            ),
          ],
